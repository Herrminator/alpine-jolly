{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [ "workarounds:reduceRepologyServerLoad" ] ,
  "enabledManagers": [ "custom.regex", "github-actions" ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [ "(^|/)alpine\\.packages$" ],
      "datasourceTemplate": "repology",
      "versioningTemplate": "loose",
      "depNameTemplate": "alpine_3_24/{{{pkg}}}",
      "matchStrings": [
        "(?<pkg>.*?)=(?<currentValue>.*)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchPackagePatterns": ["alpine_3_24"],
      "groupName": "Alpine packages",
      "groupSlug": "alpine"
    },
    {
      "matchManagers": [ "github-actions" ],
      "matchPackageNames": [ "*" ],
      "groupName": "GitHub Actions",
      "groupSlug": "actions"
    }
  ],
  "separateMajorMinor": false,
  "timezone": "Europe/Berlin"
}
